  },
  "step_patterns": {
    "six_hourly": {
      "type": "fixed_interval",
      "interval": 6,
      "max_step": 360,
      "description": "6-hourly steps from 0 to 360 hours"
    },
    "ifs_variable": {
      "type": "date_based_intervals",
      "description": "IFS variable step intervals based on forecast date",
      "date_rules": [
        {
          "before": "1990-11-15",
          "intervals": [[0, 120, 6], [120, 240, 12]]
        },
        {
          "after": "1990-11-15",
          "before": "2011-11-15",
          "intervals": [[0, 144, 3], [144, 240, 6]]
        },
        {
          "after": "2011-11-15",
          "intervals": [[0, 90, 1], [90, 144, 3], [144, 240, 6]]
        }
      ],
      "default_intervals": [[0, 90, 1], [90, 144, 3], [144, 240, 6]]
    }
  },
